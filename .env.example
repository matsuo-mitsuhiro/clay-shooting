# ============================================================
# クレー射撃大会システム — 環境変数テンプレート
#
# 使い方:
#   1. このファイルを .env.local にコピー
#   2. 各値を実際の値に置き換える（実値は開発メモ.txt 参照）
#   3. docker compose up で起動
# ============================================================

# ===== Neon PostgreSQL =====
# ローカル開発は Neon の dev branch を推奨（本番DBには接続しない）
# プーリング有り（アプリ用、サーバーレス向き）
DATABASE_URL=postgresql://USER:PASS@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# プーリング無し（migration 実行用）
DATABASE_URL_UNPOOLED=postgresql://USER:PASS@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ===== NextAuth.js =====
# 32文字以上のランダム文字列（生成: openssl rand -base64 32）
NEXTAUTH_SECRET=
# Docker 内 Next.js の公開URL
NEXTAUTH_URL=http://localhost:3000

# ===== Google OAuth =====
# Google Cloud Console で取得
# リダイレクト URI に http://localhost:3000/api/auth/callback/google を追加すること
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# ===== システム管理者 =====
# Google ログインを許可するメールアドレス（カンマ区切り複数可）
SYSTEM_ADMIN_EMAILS=matsuo@repros.co.jp

# ===== メール送信 =====
# ローカル開発: Mailtrap.io 推奨（テストメールが本物のユーザーに届かない）
# 本番: Gmail SMTP（matsuo@repros.co.jp のアプリパスワード）
EMAIL_USER=
EMAIL_PASS=
