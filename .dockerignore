# ============================================================
# Docker ビルド時に除外するファイル
# .gitignore とほぼ同じ + ビルドに不要な開発資料も除外
# ============================================================

# Git
.git
.gitignore
.gitattributes

# Node
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next
out

# 環境変数（コンテナには env_file 経由で渡す）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode
.idea
*.swp
*.swo

# ドキュメント・マニュアル（ランタイムには不要）
docs
manual
README.md
*.md

# CI/CD
.github

# その他
coverage
.nyc_output
playwright-report
test-results
