# Neon Database
# Neonコンソール (console.neon.tech) の接続情報からコピーしてください

# 接続プーリングあり (本番・サーバーレス環境向け)
DATABASE_URL=postgresql://username:password@ep-xxxx-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# 接続プーリングなし (マイグレーション実行時向け)
DATABASE_URL_UNPOOLED=postgresql://username:password@ep-xxxx-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
